<Application
    x:Class="Bakabase.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon x:Name="AppTrayIcon"
                      Icon="avares://Bakabase/Assets/favicon.ico"
                      ToolTipText="Bakabase"
                      IsVisible="True">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem x:Name="TrayOpenItem" Header="Open" />
                        <NativeMenuItem x:Name="TrayExitItem" Header="Exit" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
