<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <!-- Demo previews for Avalonia controls. See Program.cs for the available demo names. -->


    <ItemGroup>
        <PackageReference Include="Avalonia" Version="11.3.0" />
        <PackageReference Include="Avalonia.Desktop" Version="11.3.0" />
        <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.0" />
    </ItemGroup>

    <ItemGroup>
        <!--
            We reference the main app project rather than copy/move the Avalonia controls so
            the demos always use the actual production code (axaml + .cs). Bakabase.csproj
            outputs Bakabase.dll alongside the exe; the dll is what we link against here.
        -->
        <ProjectReference Include="..\..\apps\Bakabase\Bakabase.csproj" />
    </ItemGroup>

</Project>
